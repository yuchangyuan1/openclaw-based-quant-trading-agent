{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Advice Record",
  "type": "object",
  "required": ["ts", "symbol", "action", "reason_hash", "confidence", "change_vs_last"],
  "properties": {
    "ts": { "type": "string" },
    "symbol": { "type": "string" },
    "action": { "type": "string", "enum": ["observe", "hold", "increase", "reduce"] },
    "reason_hash": { "type": "string" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "change_vs_last": { "type": "string" }
  }
}
