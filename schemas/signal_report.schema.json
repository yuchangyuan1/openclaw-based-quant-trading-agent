{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Signal Report",
  "type": "object",
  "required": ["timestamp", "market", "signals", "global_risk_state"],
  "properties": {
    "timestamp": { "type": "string" },
    "market": { "type": "string" },
    "global_risk_state": { "type": "string", "enum": ["normal", "cautious", "defensive"] },
    "signals": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "symbol",
          "signal",
          "score",
          "confidence",
          "risk_level",
          "reasons",
          "evidence",
          "data_quality_gate"
        ],
        "properties": {
          "symbol": { "type": "string" },
          "signal": { "type": "string", "enum": ["observe", "hold", "increase", "reduce"] },
          "score": { "type": "number", "minimum": 0, "maximum": 1 },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "risk_level": { "type": "string", "enum": ["low", "medium", "high"] },
          "reasons": { "type": "array", "items": { "type": "string" } },
          "delta_vs_last": { "type": "string" },
          "evidence": {
            "type": "object",
            "required": ["trend", "momentum", "valuation", "volatility"],
            "properties": {
              "trend": { "type": "number" },
              "momentum": { "type": "number" },
              "valuation": { "type": "number" },
              "volatility": { "type": "number" }
            }
          },
          "data_quality_gate": {
            "type": "object",
            "required": ["passed", "quality_score"],
            "properties": {
              "passed": { "type": "boolean" },
              "quality_score": { "type": "number", "minimum": 0, "maximum": 100 }
            }
          }
        }
      }
    }
  }
}
